# ─────────────────────────────────────────────────────────────────
# Social Hub configuration
#
# One Composio key unlocks every platform. Connect each platform's
# account in the Composio dashboard, then come back to the Settings
# tab in Social Hub and click Refresh.
# ─────────────────────────────────────────────────────────────────

COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default

# Platforms to enable (comma-separated). Leave blank to enable all built-ins.
# Built-ins: instagram,facebook,tiktok
PLATFORMS=

# ── Server ──
HOST=127.0.0.1
PORT=12791

# ── Claude Code binary (autodetected if blank) ──
CLAUDE_BIN=
